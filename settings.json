	"css.lint.duplicateProperties": "warning",
	"css.lint.unknownAtRules": "ignore",
	"css.lint.unknownProperties": "warning",
	"css.lint.zeroUnits": "warning",
	//<========>SCSS<========>
	"scss.format.spaceAroundSelectorSeparator": true,
	"scss.lint.duplicateProperties": "warning",
	"scss.lint.unknownAtRules": "ignore",
	"scss.lint.unknownProperties": "warning",
	"scss.lint.zeroUnits": "warning",
	//<========>LESS<========>
	"less.format.spaceAroundSelectorSeparator": true,
	"less.lint.duplicateProperties": "warning",
	"less.lint.unknownAtRules": "ignore",
	"less.lint.unknownProperties": "warning",
	"less.lint.zeroUnits": "warning",
	//<========>JS/TS<========>
	"js/ts.preferences.quoteStyle": "double",
	"js/ts.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": false,
	"js/ts.format.semicolons": "insert",
	"js/ts.autoClosingTags.enabled": true,
	"js/ts.hover.maximumLength": 1500,
	"js/ts.updateImportsOnFileMove.enabled": "always",
	//<========>PHP<========>
	"php.problems.exclude": {
		"/": [
			416
		],
		"vendor/": true,
	},
	//<========>PYTHON<========>
