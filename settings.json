	"terminal.integrated.suggest.cdPath": "absolute",

	// Enables terminal IntelliSense suggestions (also known as autocomplete) for supported shells (Windows PowerShell, PowerShell v7+, zsh, bash, fish). This requires `terminal.integrated.shellIntegration.enabled` to be enabled and working or [manually installed](https://code.visualstudio.com/docs/terminal/shell-integration#_manual-installation-install).
	"terminal.integrated.suggest.enabled": true,

	// Controls whether the shell's inline suggestion should be detected and how it is scored.
